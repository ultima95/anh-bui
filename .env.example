# -----------------------------------------------------------------------
# Required — fill in all values before running docker compose up
# -----------------------------------------------------------------------

# PostgreSQL connection string
# Docker Compose: use service name "postgres" as hostname
# Local dev: use localhost
DATABASE_URL=postgresql://postgres:password@postgres:5432/portfolio

# Site identifier — scopes all database rows to this site.
# Use a short slug, e.g. "anh" or "john-doe".
# Each deployment (portfolio site) has a unique value here.
SITE_ID=anh

# Admin panel — password set via /admin/setup on first deploy (stored as bcrypt hash in DB)
# No ADMIN_PASSWORD env var needed.

# Session encryption secret — min 32 random characters
# Generate: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# -----------------------------------------------------------------------
# S3-compatible image storage (MinIO or equivalent)
# -----------------------------------------------------------------------

S3_ENDPOINT=https://your-minio-instance.example.com
S3_BUCKET=portfolio
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_REGION=us-east-1

# -----------------------------------------------------------------------
# Postgres container credentials (used by docker-compose.yml)
# -----------------------------------------------------------------------

POSTGRES_PASSWORD=password
